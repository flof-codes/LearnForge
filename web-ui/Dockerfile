# Stage 1: Build
FROM node:20-slim AS build
WORKDIR /app
ARG VITE_API_URL=http://localhost:3333
ARG VITE_DONATION_URL=
ARG OPERATOR_NAME=LearnForge
ARG OPERATOR_ADDRESS=
ARG OPERATOR_CITY=Austria
ARG OPERATOR_EMAIL=office@learnforge.eu
ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_DONATION_URL=${VITE_DONATION_URL}
ENV OPERATOR_NAME=${OPERATOR_NAME}
ENV OPERATOR_ADDRESS=${OPERATOR_ADDRESS}
ENV OPERATOR_CITY=${OPERATOR_CITY}
ENV OPERATOR_EMAIL=${OPERATOR_EMAIL}
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# Stage 2: Serve
FROM node:20-slim
RUN npm install -g serve
WORKDIR /app
COPY --from=build /app/dist .
EXPOSE 3000
CMD ["serve", "-s", ".", "-l", "3000"]
