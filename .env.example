# LearnForge Environment Variables
# Copy to .env and set production values:  cp .env.example .env

# ── API Authentication (required for production) ─────────────────────────
# Secret key for signing JWT tokens. MUST be changed in production.
JWT_SECRET=your-secure-jwt-secret-here

# JWT token expiration time (default: 7d)
# JWT_EXPIRES_IN=7d

# ── Database ─────────────────────────────────────────────────────────────
# PostgreSQL connection string. Docker Compose sets this automatically.
# Only needed when running api/ or mcp/ outside Docker.
# DATABASE_URL=postgresql://learnforge:learnforge@localhost:5432/learnforge

# ── Server Ports ─────────────────────────────────────────────────────────
# API and MCP server ports. Docker Compose sets these automatically.
# API_PORT=3000
# MCP_PORT=3001

# ── Image Storage ────────────────────────────────────────────────────────
# Directory for storing uploaded card images.
# Docker default: /data/images | Local MCP default: ~/.learnforge/images
# IMAGE_PATH=/data/images

# ── MCP Server ───────────────────────────────────────────────────────────
# Public URL of the MCP server (used for OAuth callbacks and image URLs)
# MCP_PUBLIC_URL=http://localhost:3001

# ── Stripe Billing ──────────────────────────────────────────────────────
# Stripe API keys and configuration (required for subscription billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_ANNUAL=price_...

# ── App URL ────────────────────────────────────────────────────────────
# Frontend URL for Stripe redirect URLs
# APP_URL=http://localhost:5173

# ── Donation Link ──────────────────────────────────────────────────────
# Stripe Payment Link for one-time donations (shown in settings + landing page)
VITE_DONATION_URL=https://donate.stripe.com/...

# ── Web UI ───────────────────────────────────────────────────────────────
# API base URL for the frontend. Set in docker-compose.yml for Docker.
# VITE_API_URL=http://localhost:3333

# ── Operator / Legal ─────────────────────────────────────────────────────
# Used in Impressum, AGB, Datenschutzerklärung. MUST be set before go-live.
OPERATOR_NAME=Your Full Name
OPERATOR_ADDRESS=Street 1
OPERATOR_CITY=1234 City, Austria
OPERATOR_EMAIL=office@learnforge.eu
